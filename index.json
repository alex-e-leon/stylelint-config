{
  "extends": [
    "stylelint-config-standard",
    "stylelint-prettier/recommended"
  ],
  "plugins": [
    "stylelint-prettier"
  ],
  "rules": {
    "at-rule-no-unknown": [true, { "ignoreAtRules": ["define-mixin", "mixin", "value"] }],
    "at-rule-empty-line-before": null,
    "nesting-selector-no-missing-scoping-root": [true, {"ignoreAtRules": ["define-mixin"]}],
    "no-invalid-position-declaration": [ true, { "ignoreAtRules": ["define-mixin"] } ],
    "custom-property-empty-line-before": null,
    "declaration-empty-line-before": null,
    "function-no-unknown": [true, {"ignoreFunctions": ["color-mod", "alpha"]}],
    "import-notation": [null],
    "keyframes-name-pattern": [null],
    "length-zero-no-unit": true,
    "no-descending-specificity": null,
    "selector-pseudo-class-no-unknown": [true, { "ignorePseudoClasses": ["global", "focus-visible"] }],
    "selector-class-pattern": ["^[a-zA-Z0-9]+$"]
  }
}
